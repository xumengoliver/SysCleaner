<UserControl x:Class="SysCleaner.Wpf.Views.SystemRepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,6,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource Brush.SurfaceMuted}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="系统修复" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}" Text="修复应用图标显示异常，以及已登录 Windows 账号但系统头像未正确同步的问题。" />
                    <WrapPanel Margin="0,18,0,0">
                        <Button Content="刷新诊断" Command="{Binding RefreshCommand}" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="修复图标缓存" Command="{Binding RepairIconCacheCommand}" />
                        <Button Style="{StaticResource WarningButtonStyle}" Content="修复账号头像" Command="{Binding RepairWindowsAvatarCommand}" />
                    </WrapPanel>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0" Padding="16" Background="White">
                        <TextBlock Text="图标修复会重建 Explorer 图标缓存；头像修复会清理当前用户头像缓存并重启壳进程。执行头像修复后，如仍未刷新，通常需要保持联网后重新登录 Windows。" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                    </Border>
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="1" Margin="0,18,0,0" ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="执行当前修复" Command="{Binding RepairItemCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="复制诊断信息" Command="{Binding CopyDiagnosticCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="刷新诊断" Command="{Binding RefreshCommand}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Brush.PrimaryText}" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding Description}" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding DetectionSummary}" TextWrapping="Wrap" Foreground="{StaticResource Brush.PrimaryText}" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding Recommendation}" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Border Style="{StaticResource ChipBorderStyle}">
                                        <TextBlock Text="{Binding Health}" />
                                    </Border>
                                    <Border Style="{StaticResource ChipBorderStyle}">
                                        <TextBlock Text="{Binding RequiresExplorerRestart, StringFormat=需重启 Explorer: {0}}" />
                                    </Border>
                                    <Border Style="{StaticResource ChipBorderStyle}">
                                        <TextBlock Text="{Binding RequiresSignOut, StringFormat=建议重新登录: {0}}" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>