<UserControl x:Class="SysCleaner.Wpf.Views.InstalledAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SysCleaner.Wpf.Behaviors">
    <UserControl.Resources>
        <Style x:Key="InstalledAppsRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Health}" Value="Broken">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Health}" Value="Broken" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FDE7E7" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource Brush.SurfaceMuted}">
            <WrapPanel ItemWidth="520" Orientation="Horizontal">
                <StackPanel Width="520" Margin="0,0,18,12">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="软件卸载" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}" Text="查看已安装软件、识别健康状态并启动卸载流程。" />
                    <Border Style="{StaticResource ChipBorderStyle}" Margin="0,18,0,0" Background="White" HorizontalAlignment="Left">
                        <TextBlock Text="建议先在列表中确认发布者、安装目录、来源和健康度，再启动卸载。" Foreground="{StaticResource Brush.SecondaryText}" />
                    </Border>
                </StackPanel>
                <WrapPanel VerticalAlignment="Top">
                    <Button Content="刷新" Command="{Binding RefreshCommand}" />
                    <Button Content="启动卸载" Command="{Binding LaunchUninstallCommand}" />
                    <CheckBox Margin="8,10,0,0" IsChecked="{Binding ShowOnlyUninstallable}" Content="仅显示可卸载项" />
                    <CheckBox Margin="8,10,0,0" IsChecked="{Binding ShowOnlyCurrentUser}" Content="仅显示当前用户安装项" />
                </WrapPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="20,16,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="已安装软件列表" />
                    <TextBlock Margin="0,6,0,0" Text="默认仅显示可卸载项；取消勾选后可查看疑似残留或命令失效的卸载入口。可选进一步限制为当前用户安装项。" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Apps}"
                          SelectedItem="{Binding SelectedApp}"
                          RowStyle="{StaticResource InstalledAppsRowStyle}"
                          behaviors:DataGridRowSelectionBehavior.DoubleClickCommand="{Binding LaunchUninstallCommand}"
                          behaviors:DataGridScrollStateBehavior.PreserveScrollOnItemsChange="True">
                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="刷新列表" Command="{Binding RefreshCommand}" />
                            <Separator />
                            <MenuItem Header="启动卸载" Command="{Binding LaunchUninstallCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="2*" />
                        <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="*" />
                        <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="*" />
                        <DataGridTextColumn Header="来源" Binding="{Binding SourceSummary}" SortMemberPath="SourceSortKey" Width="*" />
                        <DataGridTextColumn Header="安装目录" Binding="{Binding InstallLocation}" Width="2*" />
                        <DataGridTextColumn Header="注册表路径" Binding="{Binding RegistryPath}" Width="3*" />
                        <DataGridTextColumn Header="健康度" Binding="{Binding Health}" SortMemberPath="HealthSortKey" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>