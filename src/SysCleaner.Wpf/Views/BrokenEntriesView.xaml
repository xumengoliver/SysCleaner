<UserControl x:Class="SysCleaner.Wpf.Views.BrokenEntriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SysCleaner.Wpf.Behaviors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource Brush.SurfaceMuted}">
            <WrapPanel ItemWidth="520" Orientation="Horizontal">
                <StackPanel Width="520" Margin="0,0,18,12">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="失效卸载条目" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}" Text="定位卸载列表中命令失效或安装路径丢失的条目。" />
                    <Border Style="{StaticResource ChipBorderStyle}" Margin="0,18,0,0" Background="#FFF7ED" HorizontalAlignment="Left">
                        <TextBlock Text="删除前建议核对名称、发布者与注册表位置，避免误删仍可用的企业软件入口。" Foreground="{StaticResource Brush.Warning}" />
                    </Border>
                </StackPanel>
                <WrapPanel VerticalAlignment="Top">
                    <Button Content="刷新" Command="{Binding RefreshCommand}" />
                    <Button Style="{StaticResource DangerButtonStyle}" Content="删除选中条目" Command="{Binding RemoveSelectedCommand}" />
                </WrapPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="20,16,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="失效项列表" />
                    <TextBlock Margin="0,6,0,0" Text="重点关注卸载命令缺失、安装路径失效和孤立注册表项。" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          behaviors:DataGridRowSelectionBehavior.DoubleClickCommand="{Binding RemoveSelectedCommand}">
                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="刷新列表" Command="{Binding RefreshCommand}" />
                            <Separator />
                            <MenuItem Header="删除当前条目" Command="{Binding RemoveSelectedCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="2*" />
                        <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="*" />
                        <DataGridTextColumn Header="注册表位置" Binding="{Binding RegistryPath}" Width="3*" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Health}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>