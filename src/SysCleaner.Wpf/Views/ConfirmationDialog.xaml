<Window x:Class="SysCleaner.Wpf.Views.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作"
        Width="520"
        Height="Auto"
        MinHeight="288"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.AppBackground}">
    <Window.Resources>
        <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{Binding HeaderBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.14" Color="#10233A" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
                    <Setter Property="BorderBrush" Value="#991B1B" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.24" Color="#DC2626" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConfirmation}" Value="False">
                    <Setter Property="Background" Value="{StaticResource Brush.Info}" />
                    <Setter Property="BorderBrush" Value="#1D4ED8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="22"
            Effect="{StaticResource Shadow.Card}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0"
                    Padding="22"
                    Background="{Binding HeaderSurfaceBrush}"
                    BorderBrush="{Binding HeaderOutlineBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="22,22,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="52"
                                Height="52"
                                Background="White"
                                BorderBrush="{Binding HeaderOutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{Binding HeaderBrush}"
                                       Text="{Binding IconGlyph}" />
                        </Border>

                        <StackPanel Margin="16,0,0,0">
                            <TextBlock Text="{Binding Header}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding HeaderBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding Title}"
                                       FontSize="14"
                                       Foreground="{StaticResource Brush.SecondaryText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ToneDescription}"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.SecondaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            VerticalAlignment="Top"
                            Padding="12,7"
                            Background="White"
                            BorderBrush="{Binding HeaderOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Text="{Binding ToneLabel}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding HeaderBrush}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="22,18,22,0"
                    Padding="14,12"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="14">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.SecondaryText}"
                               Text="{Binding MessageCaption}" />
                    <Border DockPanel.Dock="Right"
                            Padding="10,5"
                            Background="White"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="{Binding ShortcutHint}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.SecondaryText}" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="22,14,22,0"
                    Padding="0"
                    Background="{StaticResource Brush.SurfaceMuted}"
                    BorderBrush="{Binding HeaderOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              MaxHeight="340"
                              CanContentScroll="False">
                    <TextBlock Text="{Binding Message}"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.PrimaryText}" />
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="3" Margin="22,18,22,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource Brush.SecondaryText}"
                               FontWeight="SemiBold"
                               Text="{Binding FooterText}" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{StaticResource Brush.SecondaryText}"
                               Text="{Binding FooterSubtext}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="0,0,12,0"
                        Padding="10,6"
                        Background="{StaticResource Brush.SurfaceMuted}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="10"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ToneLabel}"
                               Foreground="{Binding HeaderBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>

                <Button Grid.Column="2"
                        x:Name="CancelButton"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="{Binding CancelText}"
                    IsCancel="True" />

                <Button Grid.Column="3"
                        x:Name="ConfirmButton"
                        MinWidth="118"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        Content="{Binding ConfirmText}"
                    IsDefault="True" />
            </Grid>
        </Grid>
    </Border>
</Window>
