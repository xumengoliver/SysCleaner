<UserControl x:Class="SysCleaner.Wpf.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource Brush.SurfaceMuted}">
            <WrapPanel ItemWidth="520" Orientation="Horizontal">
                <StackPanel Width="520" Margin="0,0,18,12">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="历史记录" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}" Text="查看最近的扫描、清理和解除占用动作。" />
                    <Border Style="{StaticResource ChipBorderStyle}" Margin="0,18,0,0" Background="White" HorizontalAlignment="Left">
                        <TextBlock Text="建议在执行删除、卸载和修复后回到这里核对结果与目标对象。" Foreground="{StaticResource Brush.SecondaryText}" />
                    </Border>
                </StackPanel>
                <Button Width="120" Height="42" Margin="0,0,0,12" VerticalAlignment="Top" Content="刷新历史" Command="{Binding RefreshCommand}" />
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="20,16,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="操作记录" />
                    <TextBlock Margin="0,6,0,0" Text="按时间回溯已执行动作，可用于确认操作结果和排查异常。" TextWrapping="Wrap" Foreground="{StaticResource Brush.SecondaryText}" />
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="刷新历史" Command="{Binding RefreshCommand}" />
                            <Separator />
                            <MenuItem Header="复制当前记录" Command="{Binding CopySelectedEntryCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="2*" />
                        <DataGridTextColumn Header="模块" Binding="{Binding Module}" Width="*" />
                        <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="*" />
                        <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="2*" />
                        <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*" />
                        <DataGridTextColumn Header="详情" Binding="{Binding Details}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>