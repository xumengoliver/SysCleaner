<Application x:Class="SysCleaner.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SysCleaner.Wpf.ViewModels"
             xmlns:views="clr-namespace:SysCleaner.Wpf.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:InstalledAppsViewModel}">
                <views:InstalledAppsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SoftwarePanoramaViewModel}">
                <views:SoftwarePanoramaView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:BrokenEntriesViewModel}">
                <views:BrokenEntriesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:StartupViewModel}">
                <views:StartupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:ScheduledTasksViewModel}">
                <views:ScheduledTasksView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SystemServicesViewModel}">
                <views:SystemServicesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SystemRepairViewModel}">
                <views:SystemRepairView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:WindowsUpdateRepairViewModel}">
                <views:WindowsUpdateRepairView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:ContextMenuViewModel}">
                <views:ContextMenuView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:UnlockAssistantViewModel}">
                <views:UnlockAssistantView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:EmptyCleanupViewModel}">
                <views:EmptyCleanupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:ResidueViewModel}">
                <views:ResidueView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:RegistryViewModel}">
                <views:RegistryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:RegistrySearchViewModel}">
                <views:RegistrySearchView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:HistoryViewModel}">
                <views:HistoryView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
