<Window x:Class="SysCleaner.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SysCleaner"
        Icon="app.ico"
        Width="1480"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.AppBackground}">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="304" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource Brush.NavBackground}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="28"
                Padding="24"
                Effect="{StaticResource Shadow.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="58"
                            Height="58"
                            CornerRadius="18"
                            HorizontalAlignment="Left">
                        <Border.Background>
                            <ImageBrush ImageSource="app.ico" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <TextBlock Margin="0,18,0,0"
                               Text="SysCleaner"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.PrimaryText}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="现代化 Windows 应用治理与清理工具，聚焦扫描、定位、修复与可控清理。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.SecondaryText}" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="0,28,0,18"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="16"
                                    CornerRadius="18"
                                    Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Padding="10,4"
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Left"
                                            Background="White">
                                        <TextBlock Text="{Binding Section}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.SecondaryText}" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.PrimaryText}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.SecondaryText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource Brush.SurfaceMuted}"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="执行提示"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.PrimaryText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="当前程序默认以管理员权限运行。执行删除、卸载和修复前，先确认选中对象与影响范围。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Brush.SecondaryText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="30"
                Effect="{StaticResource Shadow.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="20,20,20,0"
                        Padding="14,12"
                        Background="{StaticResource Brush.SurfaceMuted}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource ChipBorderStyle}"
                                Margin="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="White">
                            <TextBlock Text="{Binding SelectedItem.Section, TargetNullValue=工作区}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.SecondaryText}" />
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding SelectedItem.Title, TargetNullValue=选择左侧模块开始治理}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.PrimaryText}" />

                        <Border Grid.Column="3"
                                Background="White"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Left"
                                               Margin="0,0,10,0"
                                               Text="最近状态"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Accent}" />
                                    <TextBlock Text="{Binding CurrentViewModel.StatusMessage, TargetNullValue=等待执行操作。}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.SecondaryText}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <StackPanel Margin="0,10,0,0"
                                            Visibility="{Binding CurrentViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding CurrentViewModel.BusyMessage, TargetNullValue=正在加载...}"
                                               Foreground="{StaticResource Brush.PrimaryText}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <ProgressBar Margin="0,8,0,0"
                                                 Height="8"
                                                 Value="{Binding CurrentViewModel.ProgressValue}"
                                                 Maximum="{Binding CurrentViewModel.ProgressMaximum}"
                                                 IsIndeterminate="{Binding CurrentViewModel.IsProgressIndeterminate}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="20,16,20,20" Background="Transparent">
                    <Grid>
                        <ContentControl Content="{Binding CurrentViewModel}"
                                        IsEnabled="{Binding CurrentViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}, TargetNullValue=True}" />
                        <Border Background="#CCFFFFFF"
                                CornerRadius="24"
                                Visibility="{Binding CurrentViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Border Width="360"
                                        Padding="24"
                                        Background="White"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,28,0,0"
                                        Effect="{StaticResource Shadow.Card}">
                                    <StackPanel>
                                        <TextBlock Text="正在执行"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.PrimaryText}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="{Binding CurrentViewModel.BusyMessage, TargetNullValue=正在加载，请稍候...}"
                                                   Foreground="{StaticResource Brush.SecondaryText}"
                                                   TextWrapping="Wrap" />
                                        <ProgressBar Margin="0,16,0,0"
                                                     Height="10"
                                                     Value="{Binding CurrentViewModel.ProgressValue}"
                                                     Maximum="{Binding CurrentViewModel.ProgressMaximum}"
                                                     IsIndeterminate="{Binding CurrentViewModel.IsProgressIndeterminate}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
